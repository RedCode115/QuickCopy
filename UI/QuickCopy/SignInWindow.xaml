<Window x:Class="UI.SignInWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UI"
        mc:Ignorable="d"
        Title="SignInWindow" Height="550" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock  Grid.Column="0" Grid.Row="0" Text="Sign in" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30" Grid.ColumnSpan="2"/>
        <TextBlock  Grid.Column="0" Grid.Row="1" Text="First name* :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="1" Name="firstname" Margin="3"/>
        <TextBlock  Grid.Column="0" Grid.Row="2" Text="Last name* :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="2" Name="lastname" Margin="3"/>
        <TextBlock  Grid.Column="0" Grid.Row="3" Text="E-mail* :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="3" Name="email" Margin="3"/>
        <TextBlock  Grid.Column="0" Grid.Row="4" Text="Username* :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="4" Name="username" Margin="3"/>
        <TextBlock  Grid.Column="0" Grid.Row="5" Text="Password* :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="5" Name="password" Margin="3"/>
        <TextBlock  Grid.Column="0" Grid.Row="6" Text="Password check* :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="6" Name="passwordChexk" Margin="3"/>
        <TextBlock  Grid.Column="0" Grid.Row="7" Text="Birthdate* :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="7" Name="Birtdate" Margin="3"/>
        <TextBlock  Grid.Column="0" Grid.Row="8" Text="Gender* :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="8" Name="gender" Margin="3"/>
        <TextBlock  Grid.Column="0" Grid.Row="9" Text="Country* :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="9" Name="country" Margin="3"/>
        <TextBlock  Grid.Column="0" Grid.Row="10" Text="Language* :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="10" Name="language" Margin="3"/>
        <TextBlock  Grid.Column="0" Grid.Row="11" Text="Hobby or professional :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="11" Name="professional" Margin="3"/>
        <TextBlock  Grid.Column="0" Grid.Row="12" Text="Business :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="12" Name="business" Margin="3"/>
        <TextBlock  Grid.Column="0" Grid.Row="13" Text="Sector :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="13" Name="sector" Margin="3"/>
        <TextBlock  Grid.Column="0" Grid.Row="14" Text="Position :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="14" Name="position" Margin="3"/>
        <TextBlock  Grid.Column="0" Grid.Row="15" Text="Main use* :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="15" Name="mainUse" Margin="3"/>
        <Button Grid.Column="0" Grid.Row="16" Content="Sign in" Click="ButtonVoegToe_Click" Grid.ColumnSpan="2" Margin="5"/>
        <Button Grid.Column="0" Grid.Row="17" Content="Cancel" Click="ButtonVoegToe_Click" Grid.ColumnSpan="2" Margin="5"/>
    </Grid>
</Window>
