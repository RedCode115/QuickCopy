<Window x:Class="UI.EditingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UI"
        mc:Ignorable="d"
        Title="EditingWindow" Height="500" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <Button Grid.Column="0" Grid.Row="0" Content=" Account " Click="ButtonAcount_Click" Margin="3"/>
        <Button Grid.Column="1" Grid.Row="0" Content=" Settings " Click="ButtonSettings_Click" Margin="3"/>
        <Button Grid.Column="4" Grid.Row="0" Content="  QC  " Click="ButtonQC_Click" Margin="3"/>
        <TextBlock Grid.Column="0" Grid.Row="1" Text="Name :" Margin="3"/>
        <TextBox Grid.Column="1" Grid.Row="1" Name="fileName" Grid.ColumnSpan="4" Margin="3"/>
        <TextBlock Grid.Column="0" Grid.Row="2" Text="Location :" Margin="3"/>
        <TextBox Grid.Column="1" Grid.Row="2" Name="fileLocation" Grid.ColumnSpan="4" Margin="3"/>
        <TextBox Grid.Column="0" Grid.Row="3" Name="code" Grid.ColumnSpan="5" Margin="3"/>
        <Button Grid.Column="3" Grid.Row="4" Content=" Cancel " Click="ButtonCancel_Click" Margin="3"/>
        <Button Grid.Column="4" Grid.Row="4" Content=" Save " Click="ButtonSave_Click" Margin="3"/>
    </Grid>
</Window>
