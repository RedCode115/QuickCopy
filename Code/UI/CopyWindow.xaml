<Window x:Class="UI.CopyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuickCopy"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Button Grid.Column="0" Grid.Row="0" Content="Fav" Click="ButtonFavV_Click" Grid.ColumnSpan="2" Margin="3"/>
        <Button Grid.Column="2" Grid.Row="0" Content="History" Click="ButtonHistoryV_Click" Grid.ColumnSpan="2" Margin="3"/>
        <DataGrid Grid.Row="1" Name="DataGridHistory" Margin="5" SelectionMode="Single" IsReadOnly="True" SelectionChanged="DataGridHRMedewerkers_SelectionChanged" Grid.ColumnSpan="4">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Copy"/>
                    <MenuItem Header="Add to Vault" />
                    <MenuItem Header="Delete" />
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
        <DataGrid Grid.Row="1" Name="DataGridFav" Margin="5" SelectionMode="Single" IsReadOnly="True" SelectionChanged="DataGridHRMedewerkers_SelectionChanged" Grid.ColumnSpan="4">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Copy"/>
                    <MenuItem Header="Edit" />
                    <MenuItem Header="un Fav" />
                    <MenuItem Header="Open in Vault" />
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
        <Button Grid.Column="0" Grid.Row="2" Content="Vault" Click="ButtonVault_Click" Margin="3"/>
        <Button Grid.Column="2" Grid.Row="2" Content="Settings" Click="ButtonSettings_Click" Margin="3"/>
        <Button Grid.Column="3" Grid.Row="2" Content="Account" Click="ButtonAccount_Click" Margin="3"/>
    </Grid>
</Window>
