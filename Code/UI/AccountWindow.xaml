<Window x:Class="UI.AccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UI"
        mc:Ignorable="d"
        Title="AccountWindow" Height="400" Width="350">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Grid.Row="0" VerticalAlignment="Center" FontSize="30" Grid.ColumnSpan="2"/>
        <TextBlock Grid.Column="0" Grid.Row="1" Name="FirstLastName" Margin="5" Grid.ColumnSpan="2"/>
        <TextBlock Grid.Column="0" Grid.Row="2" Text="E-mail :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="2" Name="email" Margin="3"/>
        <TextBlock Grid.Column="0" Grid.Row="3" Text="Username :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="3" Name="username" Margin="3"/>
        <TextBlock Grid.Column="0" Grid.Row="4" Text="Birthdate :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="4" Name="Birtdate" Margin="3"/>
        <TextBlock Grid.Column="0" Grid.Row="5" Text="Gender :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="5" Name="gender" Margin="3"/>
        <TextBlock Grid.Column="0" Grid.Row="6" Text="Country :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="6" Name="country" Margin="3"/>
        <TextBlock Grid.Column="0" Grid.Row="7" Text="Hobby or professional :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="7" Name="professional" Margin="3"/>
        <TextBlock Grid.Column="0" Grid.Row="8" Text="Business :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="8" Name="business" Margin="3"/>
        <TextBlock Grid.Column="0" Grid.Row="9" Text="Sector :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="9" Name="sector" Margin="3"/>
        <TextBlock Grid.Column="0" Grid.Row="10" Text="Position :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="10" Name="position" Margin="3"/>
        <TextBlock Grid.Column="0" Grid.Row="11" Text="Main use :" Margin="5"/>
        <TextBox Grid.Column="1" Grid.Row="11" Name="mainUse" Margin="3"/>
        <Button Grid.Column="1" Grid.Row="12" Content="Save" Click="ButtonSave_Click" Margin="3"/>
        <Button Grid.Column="0" Grid.Row="12" Content="Cancel" Click="ButtonCancel_Click" Margin="3"/>
    </Grid>
</Window>
